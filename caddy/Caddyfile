# ── Global rate limit ───────────────────────────────────────
{
  order rate_limit before basicauth
}

# ── Security headers (global snippet) ───────────────────────
(security_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), geolocation=()"
    -Server
  }
}

# ── Rate limiting snippets ──────────────────────────────────
(rate_limit_api) {
  rate_limit {
    zone api_zone {
      key {client.ip}
      events 60
      window 1m
    }
  }
}

(rate_limit_page) {
  rate_limit {
    zone page_zone {
      key {client.ip}
      events 120
      window 1m
    }
  }
}

# ── prittor.com ──────────────────────────────────────────────
www.prittor.com {
  redir https://prittor.com{uri} permanent
}

prittor.com {
  import security_headers
  import rate_limit_page
  encode zstd gzip
  header Link `<https://prittor.com{uri}>; rel="canonical"`
  reverse_proxy portafolio-app:80
}

# ── finanzas ─────────────────────────────────────────────────
finanzas.prittor.com, sam.prittor.com, caro.prittor.com, jessica.prittor.com, demo.prittor.com {
  import security_headers
  encode zstd gzip
  header Link `<https://{host}{uri}>; rel="canonical"`

  @api path /api*
  route @api {
    import rate_limit_api
    reverse_proxy finanzas-backend-prod:3000
  }

  import rate_limit_page
  reverse_proxy finanzas-frontend-prod:80
}

