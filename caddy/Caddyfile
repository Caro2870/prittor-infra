# ── prittor.com ──────────────────────────────────────────────
prittor.com, www.prittor.com {
  encode zstd gzip
  reverse_proxy portafolio-app:80
}

# ── finanzas ─────────────────────────────────────────────────
finanzas.prittor.com, sam.prittor.com, caro.prittor.com, jessica.prittor.com, demo.prittor.com {
  encode zstd gzip

  @api path /api*
  reverse_proxy @api finanzas-backend-prod:3000

  reverse_proxy finanzas-frontend-prod:80
}

# ── jessica nails (landing) ───────────────────────────────────
shop.prittor.com, tienda.prittor.com {
  encode zstd gzip
  reverse_proxy jessica-nails-app:80
}

# ── ecommerce nails (Laravel) ────────────────────────────────
nails.prittor.com {
  encode zstd gzip
  reverse_proxy ecommerce-nails-web:80
}

# ── atiende ───────────────────────────────────────────────────
atiende.prittor.com {
  encode zstd gzip
  reverse_proxy atiende-atiende-1:3000
}
